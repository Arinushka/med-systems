OPENAI_API_KEY=
# (optional) text embedding model
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Which embeddings provider to use.
# Use `local` for fully free mode (transformers.js).
EMBEDDINGS_PROVIDER=local

# ---- Optional: LLM judge for final match/no_match ----
# Option A: OpenAI judge (no need for Ollama)
OPENAI_JUDGE_MODEL=gpt-4o-mini

# Option B: Ollama judge (local, no API key)
# Set JUDGE_PROVIDER=ollama and OLLAMA_URL=http://localhost:11434/api/chat
# By default we use local free Ollama judge.
JUDGE_PROVIDER=ollama
OLLAMA_URL=http://localhost:11434/api/chat
OLLAMA_MODEL=qwen2.5:latest

# TenderPlan keys API token for backend proxy endpoint /api/tender-keys
TENDERPLAN_API_TOKEN=

# Control how many rows to send to judge
JUDGE_MAX_ROWS=60

# If set to "true", we will not fallback to local embeddings when OpenAI is blocked (e.g. 403/not supported).
OPENAI_FORCE=false

# If llm.confidence is below this value, we won't return "match".
JUDGE_MIN_CONFIDENCE=0.65

# Pass criterion: heuristic score must be strictly greater than this percent.
MATCH_PASS_PERCENT=82
# Hard floor: if final matchPercent is below this value, result is always no_match.
MATCH_MIN_PERCENT_FOR_COMPLIANCE=30
# Minimum matched criteria when product name gate passes.
MATCH_MIN_CRITERIA_IF_NAME_MATCH=1

# Limits for generation/time
OPENAI_JUDGE_MAX_TOKENS=300
OLLAMA_NUM_PREDICT=150

#
# (Proxy settings for OpenAI removed; use VPN/proxy at OS/network level.)

