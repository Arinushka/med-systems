OPENAI_API_KEY=
OPENAI_JUDGE_MODEL=gpt-4o-mini
OPENAI_FORCE=false
JUDGE_PROVIDER=ollama
OLLAMA_URL=http://localhost:11434/api/chat
OLLAMA_MODEL=qwen2.5:latest

# Force local embeddings (no OpenAI embeddings => no quota/429).
EMBEDDINGS_PROVIDER=local

# Route backend traffic through V2RayTun local HTTP proxy.
# Local proxy endpoint detected: 127.0.0.1:10801
HTTP_PROXY=http://127.0.0.1:10801
HTTPS_PROXY=http://127.0.0.1:10801
NO_PROXY=localhost,127.0.0.1

# Matching speed tuning
MATCH_OLLAMA_NAME_GATE_MAX_DOCS=1
JUDGE_MAX_ROWS=30
MATCH_CANDIDATE_DOCS=5
MATCH_KEYVALUE_MAX_QUERY_ROWS=25
MATCH_KEYVALUE_MAX_LIBRARY_ROWS=180
MATCH_SKIP_LLM_IF_CRITERIA_MATCH=false
MATCH_DISABLE_LLM=false
MATCH_MIN_CRITERIA_IF_NAME_MATCH=1
OLLAMA_TIMEOUT_MS=15000
OLLAMA_RETRY_ON_ABORT=false
OLLAMA_NUM_PREDICT=64
